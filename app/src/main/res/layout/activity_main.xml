<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#121212">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Blaupunkt BN40F1132EEB"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <Button android:id="@+id/btnPower" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="POWER" android:backgroundTint="#E53935" android:textColor="#FFF" android:layout_marginBottom="16dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/btnVolUp" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
            android:text="VOL +" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnChUp" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
            android:text="CH +" android:layout_marginStart="8dp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
        <Button android:id="@+id/btnVolDown" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
            android:text="VOL -" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnChDown" android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
            android:text="CH -" android:layout_marginStart="8dp"/>
    </LinearLayout>

    <Button android:id="@+id/btnMute" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="MUTE" android:layout_marginTop="16dp"/>
    <Button android:id="@+id/btnSource" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="SOURCE" android:layout_marginTop="8dp"/>
    <Button android:id="@+id/btnMenu" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="MENU" android:layout_marginTop="8dp"/>
    <Button android:id="@+id/btnOk" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="OK" android:layout_marginTop="8dp"/>

</LinearLayout>
